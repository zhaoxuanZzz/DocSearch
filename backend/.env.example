# =============================================================================
# DocSearch Backend — 环境变量配置模板
# 复制为 .env 并填写实际值
# =============================================================================

# PostgreSQL (含 pgvector + pg_search 扩展)
DATABASE_URL=postgresql+psycopg://docsearch:docsearch@localhost:5432/docsearch

# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docsearch
MINIO_SECURE=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery (使用 Redis 作为 broker 和 backend)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 嵌入模型 (sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_MAX_TOKENS=512

# 重排序模型
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_ENABLED=true
RERANKER_TOP_N=20

# 检索参数
HNSW_EF_SEARCH=100
RRF_K=60

# 路由阈值
SMALL_DOC_THRESHOLD=5
SMALL_SIZE_MB=1.0
GREP_DOC_LIMIT=20

# 分块参数
CHUNK_MAX_TOKENS=512
READ_MAX_TOKENS=2000
READ_MAX_TOKENS_LIMIT=4000

# 日志
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
